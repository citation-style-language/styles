  <!-- ========= MACROS ========= -->

  <macro name="bib-section">
    <choose>
      <if type="legal_case">
        <text value="2"/>
      </if>
      <else>
        <text value="1"/>
      </else>
    </choose>
  </macro>

  <!-- author-citation -->
  <macro name="author-citation">
    <names variable="author">
      <name form="short"
            and="text"
            delimiter=", "
            delimiter-precedes-last="never"/>
      <substitute>
        <names variable="editor"/>
        <text variable="title-short"/>
        <text variable="title"/>
      </substitute>
    </names>
  </macro>

  <!-- author-bib -->
  <macro name="author-bib">
    <names variable="author">
      <name form="long"
            name-as-sort-order="all"
            sort-separator=", "
            delimiter="; "
            delimiter-precedes-last="never"/>
      <substitute>
        <names variable="editor"/>
        <text variable="title-short"/>
        <text variable="title"/>
      </substitute>
    </names>
  </macro>

  <macro name="year-date">
    <date variable="issued">
      <date-part name="year"/>
    </date>
  </macro>

  <macro name="italic-title">
    <text variable="title" font-style="italic"/>
  </macro>

  <macro name="pages">
    <group delimiter=" ">
      <label variable="page" form="short"/>
      <text variable="page"/>
    </group>
  </macro>

  <!-- ========= CITATION ========= -->
  <citation et-al-min="3"
            et-al-use-first="1"
            disambiguate-add-year-suffix="true"
            disambiguate-add-names="true">
    <layout delimiter="; ">
      <group delimiter=", ">
        <group delimiter=" ">
          <text macro="author-citation" text-case="uppercase"/>
          <text macro="year-date" prefix="(" suffix=")"/>
        </group>
        <group delimiter=" ">
          <label variable="locator" form="short"/>
          <text variable="locator"/>
        </group>
      </group>
    </layout>
  </citation>

  <!-- ========= BIBLIOGRAPHY ========= -->
  <bibliography hanging-indent="true" et-al-min="4" et-al-use-first="1">
    <sort>
      <key macro="bib-section"/>
      <key macro="author-bib"/>
      <key macro="year-date"/>
      <key variable="title"/>
    </sort>

    <layout>
      <group delimiter=" ">
        <text macro="author-bib" text-case="uppercase"/>
        <text macro="year-date" prefix="(" suffix="):"/>
      </group>

      <choose>
        <if type="book">
          <text macro="italic-title"/>
          <group prefix=" (" suffix=")" delimiter=", ">
            <text variable="publisher-place"/>
            <text variable="publisher"/>
          </group>
        </if>

        <else-if type="chapter">
          <text variable="title" quotes="true"/>
          <text value=","/>
          <text value="en:"/>
          <names variable="editor" prefix=" " suffix=", ">
            <name form="long" name-as-sort-order="all" sort-separator=", "/>
          </names>
          <text variable="container-title" font-style="italic"/>
          <group prefix=" (" suffix=")" delimiter=", ">
            <text variable="publisher-place"/>
            <text variable="publisher"/>
          </group>
          <group delimiter=", ">
            <text variable="collection-title"/>
            <text macro="pages"/>
          </group>
        </else-if>

        <else-if type="article-journal">
          <text variable="title" quotes="true"/>
          <text value=","/>
          <text value=" en:"/>
          <text variable="container-title" prefix=" " font-style="italic"/>
          <group prefix=" (" suffix=")" delimiter=", ">
            <text variable="volume" prefix="Vol. "/>
            <text variable="issue" prefix="Nº "/>
          </group>
          <text macro="pages" prefix=", "/>
        </else-if>

        <else-if type="legal_case">
          <group delimiter=", ">
            <text variable="authority"/>
            <text variable="number" prefix="rol: "/>
            <date variable="issued" form="text"/>
          </group>
        </else-if>

        <else>
          <text variable="title" quotes="true"/>
          <group prefix=". Disponible en: " delimiter=" ">
            <text variable="URL"/>
            <date variable="accessed" prefix="[" suffix="]">
              <date-part name="day" suffix="/"/>
              <date-part name="month" suffix="/"/>
              <date-part name="year"/>
            </date>
          </group>
        </else>
      </choose>
      <text value="."/>
    </layout>
  </bibliography>

</style>
