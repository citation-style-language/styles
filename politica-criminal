    <link href="http://www.zotero.org/styles/politica-criminal" rel="self"/>
    <link href="http://www.zotero.org/styles/iso690-author-date-es" rel="template"/>
    <link href="https://politcrim.com/normas-editoriales/" rel="documentation"/>

    <category citation-format="note"/>
    <category field="law"/>
    <category field="social_science"/>
    <eissn>0718-3399</eissn>

    <author>
      <name>Claudio Aguero San Juan</name>
      <email>aguero.claudio@gmail.com</email>
