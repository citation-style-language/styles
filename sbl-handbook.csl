<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0" demote-non-dropping-particle="sort-only" initialize-with=". " page-range-format="chicago">
  <info>
    <title>The SBL Handbook of Style</title>
    <title-short>SBL</title-short>
    <id>http://www.zotero.org/styles/sbl-handbook</id>
    <link href="http://www.zotero.org/styles/sbl-handbook" rel="self"/>
    <link href="http://www.zotero.org/styles/chicago-author-date" rel="template"/>
    <link href="https://www.sbl-site.org/publications/SBLHandbookofStyle.aspx" rel="documentation"/>
    <author>
      <name>Matěj Cepl</name>
    </author>
    <contributor>
      <name>OpenAI</name>
    </contributor>
    <category citation-format="author-date"/>
    <category field="humanities"/>
    <category field="theology"/>
    <summary>Author-date CSL style for the Society of Biblical Literature Handbook of Style, adapted for Zotero and CSL 1.0.2 processors.</summary>
    <issn>0021-9231</issn>
    <eissn>2325-5300</eissn>
    <updated>2026-04-17T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <locale xml:lang="en">
    <style-options punctuation-in-quote="false"/>
    <terms>
      <term name="no date">n.d.</term>
      <term form="short" name="editortranslator">
        <single>ed. and trans.</single>
        <multiple>eds. and trans.</multiple>
      </term>
      <term form="short" name="editor-translator">
        <single>ed. and trans.</single>
        <multiple>eds. and trans.</multiple>
      </term>
    </terms>
  </locale>

  <macro name="author-bib">
    <names variable="author">
      <name and="text" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="first" sort-separator=", "/>
      <label form="short" prefix=", "/>
      <substitute>
        <names variable="editor">
          <name and="text" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="first" sort-separator=", "/>
          <label form="short" prefix=", "/>
        </names>
        <names variable="translator">
          <name and="text" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="first" sort-separator=", "/>
          <label form="short" prefix=", "/>
        </names>
        <text macro="title"/>
      </substitute>
    </names>
  </macro>

  <macro name="author-short">
    <names variable="author">
      <name form="short" and="text" delimiter=", " delimiter-precedes-last="always"/>
      <et-al font-style="italic"/>
      <substitute>
        <names variable="editor">
          <name form="short" and="text" delimiter=", " delimiter-precedes-last="always"/>
          <label form="short" prefix=", "/>
        </names>
        <names variable="translator">
          <name form="short" and="text" delimiter=", " delimiter-precedes-last="always"/>
          <label form="short" prefix=", "/>
        </names>
        <text macro="title-short"/>
      </substitute>
    </names>
  </macro>

  <macro name="editor-by">
    <names variable="editor">
      <label form="verb" suffix=" "/>
      <name and="text" delimiter=", " delimiter-precedes-last="always"/>
    </names>
  </macro>

  <macro name="translator-by">
    <names variable="translator">
      <label form="verb" suffix=" "/>
      <name and="text" delimiter=", " delimiter-precedes-last="always"/>
    </names>
  </macro>

  <macro name="secondary-contributors">
    <choose>
      <if variable="author">
        <group delimiter=", ">
          <text macro="editor-by"/>
          <text macro="translator-by"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="title">
    <choose>
      <if type="article-journal article-magazine article-newspaper chapter entry entry-dictionary entry-encyclopedia paper-conference post post-weblog review review-book webpage speech" match="any">
        <text variable="title" quotes="true"/>
      </if>
      <else-if type="bill legal_case legislation treaty" match="any">
        <text variable="title"/>
      </else-if>
      <else>
        <text variable="title" font-style="italic"/>
      </else>
    </choose>
  </macro>

  <macro name="title-short">
    <choose>
      <if type="article-journal article-magazine article-newspaper chapter entry entry-dictionary entry-encyclopedia paper-conference post post-weblog review review-book webpage speech" match="any">
        <text variable="title" form="short" quotes="true"/>
      </if>
      <else-if type="bill legal_case legislation treaty" match="any">
        <text variable="title" form="short"/>
      </else-if>
      <else>
        <text variable="title" form="short" font-style="italic"/>
      </else>
    </choose>
  </macro>

  <macro name="container-title">
    <text variable="container-title" font-style="italic"/>
  </macro>

  <macro name="issued-year">
    <choose>
      <if variable="issued">
        <group>
          <date variable="issued">
            <date-part name="year"/>
          </date>
          <text variable="year-suffix"/>
        </group>
      </if>
      <else>
        <group>
          <text term="no date"/>
          <text variable="year-suffix"/>
        </group>
      </else>
    </choose>
  </macro>

  <macro name="issued-sort">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text value="9999"/>
      </else>
    </choose>
  </macro>

  <macro name="issued-full">
    <choose>
      <if variable="issued">
        <date variable="issued" form="text"/>
      </if>
    </choose>
  </macro>

  <macro name="edition">
    <choose>
      <if is-numeric="edition">
        <group delimiter=" ">
          <number variable="edition" form="ordinal"/>
          <text term="edition" form="short"/>
        </group>
      </if>
      <else>
        <text variable="edition"/>
      </else>
    </choose>
  </macro>

  <macro name="volume">
    <group delimiter=" ">
      <choose>
        <if is-numeric="volume">
          <label variable="volume" form="short"/>
        </if>
      </choose>
      <text variable="volume"/>
    </group>
  </macro>

  <macro name="number-of-volumes">
    <group delimiter=" ">
      <text variable="number-of-volumes"/>
      <choose>
        <if is-numeric="number-of-volumes">
          <label variable="number-of-volumes" form="short"/>
        </if>
      </choose>
    </group>
  </macro>

  <macro name="number">
    <group delimiter=" ">
      <choose>
        <if is-numeric="number">
          <label variable="number" form="short"/>
        </if>
      </choose>
      <text variable="number"/>
    </group>
  </macro>

  <macro name="collection">
    <group delimiter=" ">
      <text variable="collection-title"/>
      <text variable="collection-number"/>
    </group>
  </macro>

  <macro name="publisher">
    <group delimiter=": ">
      <text variable="publisher-place"/>
      <text variable="publisher"/>
    </group>
  </macro>

  <macro name="access">
    <choose>
      <if variable="DOI">
        <text variable="DOI" prefix="https://doi.org/"/>
      </if>
      <else-if variable="URL">
        <choose>
          <if variable="accessed">
            <group delimiter=", ">
              <group delimiter=" ">
                <text term="accessed"/>
                <date variable="accessed" form="text"/>
              </group>
              <text variable="URL"/>
            </group>
          </if>
          <else>
            <text variable="URL"/>
          </else>
        </choose>
      </else-if>
    </choose>
  </macro>

  <macro name="pages">
    <text variable="page"/>
  </macro>

  <macro name="pages-labeled">
    <choose>
      <if variable="page">
        <group delimiter=" ">
          <text value="Pages"/>
          <text variable="page"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="volume-of-container">
    <choose>
      <if variable="volume container-title" match="all">
        <group delimiter=" ">
          <group delimiter=" ">
            <label variable="volume" form="short"/>
            <text variable="volume"/>
          </group>
          <text value="of"/>
          <text macro="container-title"/>
        </group>
      </if>
      <else-if variable="container-title">
        <text macro="container-title"/>
      </else-if>
    </choose>
  </macro>

  <macro name="book-parent">
    <choose>
      <if variable="volume container-title" match="all">
        <group delimiter=" ">
          <group delimiter=" ">
            <label variable="volume" form="short"/>
            <text variable="volume"/>
          </group>
          <text value="of"/>
          <text variable="container-title" font-style="italic"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="pages-in-volume">
    <choose>
      <if variable="page volume container-title" match="all">
        <group delimiter=" ">
          <text value="Pages"/>
          <text variable="page"/>
          <text value="in"/>
          <text macro="volume-of-container"/>
        </group>
      </if>
      <else-if variable="page">
        <group delimiter=" ">
          <text value="Pages"/>
          <text variable="page"/>
        </group>
      </else-if>
      <else-if variable="volume container-title" match="all">
        <text macro="volume-of-container"/>
      </else-if>
    </choose>
  </macro>

  <macro name="locator">
    <group delimiter=" ">
      <choose>
        <if locator="page"/>
        <else-if locator="chapter verse line" match="any"/>
        <else>
          <label variable="locator" form="short"/>
        </else>
      </choose>
      <text variable="locator"/>
    </group>
  </macro>

  <macro name="review-description">
    <choose>
      <if variable="reviewed-title reviewed-author" match="any">
        <group delimiter=" ">
          <text value="Review of"/>
          <text variable="reviewed-title" font-style="italic"/>
          <names variable="reviewed-author" prefix=", by ">
            <name and="text" delimiter=", " delimiter-precedes-last="always"/>
          </names>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="journal-source">
    <group delimiter=" ">
      <text macro="container-title"/>
      <group>
        <text variable="volume"/>
        <group prefix=", ">
          <label variable="issue" form="short"/>
          <text variable="issue" prefix=" "/>
        </group>
      </group>
      <text macro="pages" prefix=": "/>
    </group>
  </macro>

  <macro name="chapter-source">
    <choose>
      <if variable="page volume container-title" match="all">
        <group delimiter=". ">
          <text macro="pages-in-volume"/>
          <group delimiter=", ">
            <text macro="editor-by"/>
            <text macro="translator-by"/>
            <text macro="number-of-volumes"/>
          </group>
          <text macro="publisher"/>
        </group>
      </if>
      <else>
        <group delimiter=", ">
          <group delimiter=" ">
            <text value="In"/>
            <text macro="container-title"/>
          </group>
          <text macro="editor-by"/>
          <text macro="translator-by"/>
          <text macro="edition"/>
          <text macro="volume"/>
          <text macro="collection"/>
          <text macro="pages-labeled"/>
          <text macro="publisher"/>
        </group>
      </else>
    </choose>
  </macro>

  <macro name="book-source">
    <group delimiter=". ">
      <group delimiter=", ">
        <text macro="secondary-contributors"/>
        <text macro="edition"/>
        <text macro="book-parent"/>
        <text macro="volume"/>
        <text macro="number"/>
        <text macro="collection"/>
        <text macro="number-of-volumes"/>
      </group>
      <text macro="publisher"/>
    </group>
  </macro>

  <macro name="thesis-source">
    <group delimiter=". ">
      <group delimiter=", ">
        <text variable="genre"/>
        <text variable="publisher"/>
      </group>
      <choose>
        <if variable="archive">
          <group delimiter=", ">
            <text variable="archive"/>
            <text variable="archive-place"/>
          </group>
        </if>
      </choose>
    </group>
  </macro>

  <macro name="paper-source">
    <choose>
      <if variable="container-title">
        <text macro="chapter-source"/>
      </if>
      <else>
        <group delimiter=", ">
          <group delimiter=" ">
            <text value="Paper presented at"/>
            <text variable="event-title"/>
          </group>
          <text variable="event-place"/>
          <text macro="issued-full"/>
        </group>
      </else>
    </choose>
  </macro>

  <macro name="entry-source">
    <choose>
      <if variable="page volume container-title" match="all">
        <group delimiter=". ">
          <text macro="pages-in-volume"/>
          <group delimiter=", ">
            <text macro="editor-by"/>
            <text macro="translator-by"/>
            <text macro="number-of-volumes"/>
          </group>
          <text macro="publisher"/>
        </group>
      </if>
      <else>
        <group delimiter=", ">
          <group delimiter=" ">
            <text value="In"/>
            <text macro="container-title"/>
          </group>
          <text macro="editor-by"/>
          <text macro="translator-by"/>
          <text macro="edition"/>
          <text macro="volume"/>
          <text macro="publisher"/>
          <text macro="pages-labeled"/>
        </group>
      </else>
    </choose>
  </macro>

  <macro name="web-source">
    <group delimiter=", ">
      <text macro="container-title"/>
      <text macro="issued-full"/>
    </group>
  </macro>

  <macro name="default-entry">
    <group delimiter=". ">
      <text macro="author-bib"/>
      <text macro="issued-year"/>
      <text macro="title"/>
      <text macro="book-source"/>
      <text macro="access"/>
    </group>
  </macro>

  <macro name="bibliography-entry">
    <choose>
      <if type="article-journal" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="journal-source"/>
          <text macro="access"/>
        </group>
      </if>
      <else-if type="article-magazine article-newspaper post post-weblog webpage" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="web-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else-if type="chapter" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="chapter-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else-if type="paper-conference" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="paper-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else-if type="entry entry-dictionary entry-encyclopedia" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="entry-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else-if type="review review-book" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <group delimiter=". ">
            <text macro="title"/>
            <text macro="review-description"/>
          </group>
          <text macro="journal-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else-if type="thesis" match="any">
        <group delimiter=". ">
          <text macro="author-bib"/>
          <text macro="issued-year"/>
          <text macro="title"/>
          <text macro="thesis-source"/>
          <text macro="access"/>
        </group>
      </else-if>
      <else>
        <text macro="default-entry"/>
      </else>
    </choose>
  </macro>

  <citation et-al-min="4" et-al-use-first="1" disambiguate-add-year-suffix="true" disambiguate-add-names="true" disambiguate-add-givenname="true" collapse="year">
    <sort>
      <key macro="author-short"/>
      <key macro="issued-sort"/>
      <key variable="title"/>
    </sort>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=", ">
        <group delimiter=" ">
          <text macro="author-short"/>
          <text macro="issued-year"/>
        </group>
        <text macro="locator"/>
      </group>
    </layout>
  </citation>

  <bibliography hanging-indent="true" entry-spacing="0" line-spacing="1">
    <sort>
      <key macro="author-bib"/>
      <key macro="issued-sort"/>
      <key variable="title"/>
    </sort>
    <layout suffix=".">
      <text macro="bibliography-entry"/>
    </layout>
  </bibliography>
</style>
